# ══════════════════════════════════════════════════════════════
# Personal AI Memory System — 环境变量配置
# 复制为 .env 并填入实际值
# ══════════════════════════════════════════════════════════════

# ── 必填：LLM 配置（选一个场景）────────────────────────────────

# 场景 A：OpenAI
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-...

# 场景 B：Anthropic Claude（注释掉场景 A 后使用）
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-haiku-20241022
# ANTHROPIC_API_KEY=sk-ant-...

# 场景 C：Azure OpenAI
# LLM_PROVIDER=azure
# LLM_MODEL=gpt-4o-mini            # Azure 部署名
# LLM_API_KEY=your-azure-key
# LLM_BASE_URL=https://YOUR-RESOURCE.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-01

# 场景 D：Ollama（本地）
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:7b             # ollama list 查看已安装模型
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama               # Ollama 不需要真实 key，随便填

# 场景 E：LM Studio / 任意 OpenAI 兼容服务
# LLM_PROVIDER=openai_compatible
# LLM_MODEL=local-model
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=not-needed

# ── Embedding（留空则与 LLM 使用同一提供商）────────────────────
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# Ollama embedding 示例：
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# （EMBEDDING_DIM 需与模型输出维度一致，nomic-embed-text = 768）
# EMBEDDING_DIM=768

# ── 必填：安全配置 ───────────────────────────────────────────────
TOKEN_MASTER_PASSWORD=your-secure-password-here
API_SECRET_KEY=your-api-secret-key-here

# ── 平台认证凭证 ─────────────────────────────────────────────────
# B站、抖音：扫码登录，无需凭证
# GitHub：优先使用 PAT（无需申请应用）
# GITHUB_PAT=ghp_...

# YouTube（需在 Google Cloud Console 创建 OAuth 应用）
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=

# Twitter / X（需在 Twitter Developer Portal 创建应用）
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# Pocket（在 https://getpocket.com/developer/apps/ 创建应用）
# POCKET_CONSUMER_KEY=

# 微信收藏（需企业微信开放 API 权限）
# WECHAT_API_KEY=

# 小红书（网页版 Cookie，有效期约 30 天，在平台管理页设置）
# XIAOHONGSHU_COOKIE=

# ── 同步配置 ─────────────────────────────────────────────────────
SYNC_INTERVAL_HOURS=6
TOP_K_RESULTS=5

# ── Whisper 语音识别 ─────────────────────────────────────────────
WHISPER_MODEL_SIZE=base
# WHISPER_DEVICE=cuda   # 有 NVIDIA GPU 时启用

# ── 语音播报（可选，需安装 TTS 库）─────────────────────────────
TTS_ENABLED=false
# TTS_LANGUAGE=zh-cn

# ── Web API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
OAUTH_CALLBACK_BASE=http://localhost:8000
